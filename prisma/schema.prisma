// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CORE MODELS ============

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  username          String    @unique
  password_hash     String
  
  // Profile
  avatar            String?
  bio               String?
  location          String?
  
  // Tier system (Free, Creator, Studio)
  tier              String    @default("FREE")
  tier_expires      DateTime?
  
  // Creator metadata
  specialty         String?   // JSON: ["Director", "Writer"]
  hourly_rate       Float?
  availability      String    @default("available")
  
  // Social stats
  followers_count   Int       @default(0)
  following_count   Int       @default(0)
  
  // Relations
  projects          Project[]
  scripts           Script[]
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  
  @@map("users")
}

model Script {
  id                String    @id @default(cuid())
  user_id           String
  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  title             String
  content           String    @db.Text
  status            String    @default("draft")
  visibility        String    @default("private")
  
  // Parsed data (from ScriptOS)
  characters        String?   @db.Text // JSON array
  scenes            String?   @db.Text // JSON array
  
  // Metadata
  page_count        Int       @default(0)
  word_count        Int       @default(0)
  
  // Project link
  project_id        String?
  project           Project?  @relation(fields: [project_id], references: [id], onDelete: SetNull)
  
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  
  @@index([user_id])
  @@map("scripts")
}

model Project {
  id                String    @id @default(cuid())
  creator_id        String
  creator           User      @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  
  title             String
  description       String?   @db.Text
  status            String    @default("concept")
  genre             String?
  
  // Visual
  cover_image       String?   // URL to R2
  trailer_video     String?   // URL to R2
  
  // Visibility
  visibility        String    @default("private")
  featured          Boolean   @default(false)
  
  // Budget & Timeline (Phase 3)
  budget            Float?
  deadline          DateTime?
  
  // Relations
  scripts           Script[]
  assets            ProjectAsset[]
  crew              ProjectCrew[]
  timeline          TimelineItem[]
  budget_items      BudgetItem[]
  comments          ProjectComment[]
  
  // Stats
  views             Int       @default(0)
  likes             Int       @default(0)
  
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  
  @@index([creator_id])
  @@map("projects")
}

model ProjectAsset {
  id                String    @id @default(cuid())
  project_id        String
  project           Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  
  title             String
  type              String    // "storyboard", "concept", "video", "still", "document"
  url               String    // R2 URL
  description       String?
  
  created_at        DateTime  @default(now())
  
  @@index([project_id])
  @@map("project_assets")
}

model ProjectCrew {
  id            String    @id @default(cuid())
  project_id    String
  project       Project   @relation("crew", fields: [project_id], references: [id], onDelete: Cascade)
  user_id       String
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  role          String    // "Director", "Producer", "Writer", "DP", etc.
  hourly_rate   Float?
  assigned_at   DateTime  @default(now())
  
  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
  @@map("project_crews")
}

model TimelineItem {
  id            String    @id @default(cuid())
  project_id    String
  project       Project   @relation("timeline", fields: [project_id], references: [id], onDelete: Cascade)
  
  phase         String    // "Development", "Pre-Production", "Production", "Post", "Release"
  title         String
  description   String?   @db.Text
  start_date    DateTime
  end_date      DateTime
  completion    Int       @default(0) // 0-100%
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  @@unique([project_id, id])
  @@index([project_id])
  @@map("timeline_items")
}

model BudgetItem {
  id            String    @id @default(cuid())
  project_id    String
  project       Project   @relation("budget_items", fields: [project_id], references: [id], onDelete: Cascade)
  
  category      String    // "Crew", "Equipment", "Location", "Post-Production", etc.
  description   String
  amount        Float
  actual_cost   Float?    @default(0)
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  @@unique([project_id, id])
  @@index([project_id])
  @@map("budget_items")
}

model ProjectComment {
  id            String    @id @default(cuid())
  project_id    String
  project       Project   @relation("comments", fields: [project_id], references: [id], onDelete: Cascade)
  user_id       String
  
  content       String    @db.Text
  is_edited     Boolean   @default(false)
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  @@unique([project_id, id])
  @@index([project_id])
  @@index([user_id])
  @@map("project_comments")
}

model Message {
  id                String    @id @default(cuid())
  user_id           String
  project_id        String?
  
  content           String    @db.Text
  is_edited         Boolean   @default(false)
  
  created_at        DateTime  @default(now())
  
  @@map("messages")
}
